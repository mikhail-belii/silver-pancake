<databaseChangeLog xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
                   xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
                   xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
                   http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.20.xsd">

    <changeSet id="AddNameToTeam" author="MSidorov">
        <addColumn tableName="team">
            <column name="name" type="VARCHAR(255)"/>
        </addColumn>
    </changeSet>

    <changeSet id="AddDraftId" author="MSidorov">
        <addColumn tableName="team">
            <column name="draft_id" type="UUID"/>
        </addColumn>
        <addForeignKeyConstraint baseTableName="team" baseColumnNames="draft_id"
                                 constraintName="fk_team_draft" referencedTableName="draft"
                                 referencedColumnNames="id"/>
    </changeSet>

</databaseChangeLog>
