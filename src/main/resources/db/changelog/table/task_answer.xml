<databaseChangeLog xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
                   xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
                   xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
                   http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.20.xsd">

    <changeSet id="CreateTaskAnswerTable" author="MSidorov">
        <createTable tableName="task_answer">
            <column name="id" type="UUID">
                <constraints nullable="false" primaryKey="true" primaryKeyName="pk_task_answer"/>
            </column>
            <column name="score" type="INT" defaultValueNumeric="0">
                <constraints nullable="false"/>
            </column>
            <column name="submitted_at" type="TIMESTAMP"/>
            <column name="status" type="VARCHAR(32)" defaultValue="NOT_COMPLETED">
                <constraints nullable="false"/>
            </column>
            <column name="user_id" type="UUID">
                <constraints nullable="false"/>
            </column>
            <column name="task_id" type="UUID">
                <constraints nullable="false"/>
            </column>
        </createTable>
    </changeSet>

    <changeSet id="AddTaskAnswerForeignKeys" author="MSidorov">
        <addForeignKeyConstraint baseTableName="task_answer"
                                 baseColumnNames="user_id"
                                 constraintName="fk_task_answer_user"
                                 referencedTableName="user"
                                 referencedColumnNames="id"/>

        <addForeignKeyConstraint baseTableName="task_answer"
                                 baseColumnNames="task_id"
                                 constraintName="fk_task_answer_task"
                                 referencedTableName="task"
                                 referencedColumnNames="id"/>
    </changeSet>

    <changeSet id="RemoveDeprecatedTaskAnswerColumns" author="aleksey.z">
        <dropColumn tableName="task_answer" columnName="score"/>
        <dropColumn tableName="task_answer" columnName="submitted_at"/>
        <dropColumn tableName="task_answer" columnName="status"/>
    </changeSet>

    <changeSet id="MakeTaskAnswerColumnsNullable" author="aleksey.z">
        <dropNotNullConstraint tableName="task_answer"
                               columnName="user_id"
                               columnDataType="UUID"/>
        <dropNotNullConstraint tableName="task_answer"
                               columnName="task_id"
                               columnDataType="UUID"/>
    </changeSet>

    <changeSet id="AddTaskAnswerTeamFinalTaskAnswerRelation" author="aleksey.z">
        <addColumn tableName="task_answer">
            <column name="uploaded_at" type="TIMESTAMP" defaultValueComputed="CURRENT_TIMESTAMP"/>
        </addColumn>
    </changeSet>

    <changeSet id="RemoveTaskAnswerTeamFinalTaskAnswerRelation" author="aleksey.z">
        <preConditions onFail="MARK_RAN">
            <columnExists tableName="task_answer" columnName="team_final_task_answer_id"/>
        </preConditions>

        <dropForeignKeyConstraint baseTableName="task_answer"
                                  constraintName="fk_task_answer_team_final_task_answer"/>

        <dropUniqueConstraint tableName="task_answer"
                              constraintName="uk_task_answer_team_final_task_answer"/>

        <dropColumn tableName="task_answer"
                    columnName="team_final_task_answer_id"/>
    </changeSet>

    <changeSet id="AddVotesToTaskAnswer" author="aleksey.z">
        <addColumn tableName="task_answer">
            <column name="votes" type="INT" defaultValueNumeric="0">
                <constraints nullable="false"/>
            </column>
        </addColumn>
    </changeSet>

    <changeSet id="ReplaceVotesColumnWithTaskAnswerVoteTable" author="aleksey.z">
        <dropColumn tableName="task_answer" columnName="votes"/>

        <createTable tableName="task_answer_vote">
            <column name="task_answer_id" type="UUID">
                <constraints nullable="false"/>
            </column>
            <column name="user_id" type="UUID">
                <constraints nullable="false"/>
            </column>
        </createTable>

        <addPrimaryKey tableName="task_answer_vote"
                       columnNames="task_answer_id, user_id"
                       constraintName="pk_task_answer_vote"/>

        <addForeignKeyConstraint baseTableName="task_answer_vote"
                                 baseColumnNames="task_answer_id"
                                 constraintName="fk_task_answer_vote_task_answer"
                                 referencedTableName="task_answer"
                                 referencedColumnNames="id"/>

        <addForeignKeyConstraint baseTableName="task_answer_vote"
                                 baseColumnNames="user_id"
                                 constraintName="fk_task_answer_vote_user"
                                 referencedTableName="user"
                                 referencedColumnNames="id"/>
    </changeSet>

</databaseChangeLog>
